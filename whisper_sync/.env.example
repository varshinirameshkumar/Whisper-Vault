# Copy to .env and fill in values. NEVER commit .env to git.

# Generate a random 64+ char string
JWT_SECRET=your-super-long-random-jwt-secret-here

# Generate with Java: EncryptionService.generateBase64Key()
ENCRYPTION_KEY=your-base64-encoded-aes-256-key-here

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/whispervault

# SMTP credentials
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

FRONTEND_URL=http://localhost:5173
